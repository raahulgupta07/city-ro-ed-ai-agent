# =============================================================================
# RO-ED AI Agent — Environment Configuration
# Copy this file: cp .env.example .env  then fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED
# -----------------------------------------------------------------------------

# OpenRouter API key (get one at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# JWT secret for token signing — generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# -----------------------------------------------------------------------------
# ADMIN USER (used on first DB init when no users exist)
# -----------------------------------------------------------------------------

ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=admin123

# -----------------------------------------------------------------------------
# KEYCLOAK SSO (optional — leave empty to use local auth)
# Can also be configured via Settings page in the UI
# -----------------------------------------------------------------------------

# KEYCLOAK_REALM_URL=https://your-keycloak.example.com/realms/your-realm
# KEYCLOAK_CLIENT_ID=ro-ed-client
# KEYCLOAK_CLIENT_SECRET=
# KEYCLOAK_ADMIN_ROLE=admin
